// Settings to run the workflow on Sasquatch

//working directory for temporary/intermediate files produced in the workflow processes
workDir = "/data/hps/assoc/private/${env("ASSOC")}/user/${env("USER")}/temp_deepvariant"

profiles{
    sasquatch {
        process.executor = 'slurm'
        process.queue = 'cpu-core'
        process.memory = 7500.MB
        process.time = {env("ASSOC") == 'core' ? 4.h : 72.h}
        process.clusterOptions = "--account ${env("ASSOC")}"
        docker.enabled = false
        params.enable_conda = false
    }
}

singularity {
    enabled = true
    autoMounts = true
    //cacheDir = "/data/hps/assoc/private/${params.assoc}/container/rare-disease-wf" // If you want your own cache
    cacheDir = "/data/hps/assoc/public/bioinformatics/container/rare-disease-wf/" // Public, read-only cache
    runOptions = '--containall --no-home'
    pullTimeout = 40.m
}
